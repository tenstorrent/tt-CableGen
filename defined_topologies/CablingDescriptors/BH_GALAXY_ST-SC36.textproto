        # Ring 4 (0->5->7->6->0), i=0, j=2 -- mixed (0,5 are 2nd j=2; 7,6 are 1st j=2)
        connections { port_a { path: ["bh_galaxy_sp_0", "bh_galaxy_node_0", "node_0"] tray_id: 2 port_id: 6 } port_b { path: ["bh_galaxy_sp_5", "bh_galaxy_node_1", "node_0"] tray_id: 2 port_id: 6 } }
        connections { port_a { path: ["bh_galaxy_sp_5", "bh_galaxy_node_0", "node_0"] tray_id: 2 port_id: 6 } port_b { path: ["bh_galaxy_sp_7", "bh_galaxy_node_1", "node_0"] tray_id: 1 port_id: 6 } }
        connections { port_a { path: ["bh_galaxy_sp_7", "bh_galaxy_node_0", "node_0"] tray_id: 1 port_id: 6 } port_b { path: ["bh_galaxy_sp_6", "bh_galaxy_node_1", "node_0"] tray_id: 1 port_id: 6 } }
        connections { port_a { path: ["bh_galaxy_sp_6", "bh_galaxy_node_0", "node_0"] tray_id: 1 port_id: 6 } port_b { path: ["bh_galaxy_sp_0", "bh_galaxy_node_1", "node_0"] tray_id: 2 port_id: 6 } }
        connections { port_a { path: ["bh_galaxy_sp_0", "bh_galaxy_node_2", "node_0"] tray_id: 4 port_id: 6 } port_b { path: ["bh_galaxy_sp_5", "bh_galaxy_node_2", "node_0"] tray_id: 2 port_id: 6 } }
        connections { port_a { path: ["bh_galaxy_sp_5", "bh_galaxy_node_2", "node_0"] tray_id: 4 port_id: 6 } port_b { path: ["bh_galaxy_sp_7", "bh_galaxy_node_2", "node_0"] tray_id: 1 port_id: 6 } }
        connections { port_a { path: ["bh_galaxy_sp_7", "bh_galaxy_node_2", "node_0"] tray_id: 3 port_id: 6 } port_b { path: ["bh_galaxy_sp_6", "bh_galaxy_node_2", "node_0"] tray_id: 1 port_id: 6 } }
        connections { port_a { path: ["bh_galaxy_sp_6", "bh_galaxy_node_2", "node_0"] tray_id: 3 port_id: 6 } port_b { path: ["bh_galaxy_sp_0", "bh_galaxy_node_2", "node_0"] tray_id: 2 port_id: 6 } }
        # Ring 5 (1->3->8->7->1), i=0, j=3 -- all 1st j=3, LT1 uniform on tray 3
        connections { port_a { path: ["bh_galaxy_sp_1", "bh_galaxy_node_0", "node_0"] tray_id: 3 port_id: 6 } port_b { path: ["bh_galaxy_sp_3", "bh_galaxy_node_1", "node_0"] tray_id: 3 port_id: 6 } }
