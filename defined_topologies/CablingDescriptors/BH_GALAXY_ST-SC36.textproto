        connections { port_a { path: ["bh_galaxy_sp_3", "bh_galaxy_node_0", "node_0"] tray_id: 2 port_id: 6 } port_b { path: ["bh_galaxy_sp_5", "bh_galaxy_node_1", "node_0"] tray_id: 1 port_id: 6 } }
        connections { port_a { path: ["bh_galaxy_sp_5", "bh_galaxy_node_0", "node_0"] tray_id: 1 port_id: 6 } port_b { path: ["bh_galaxy_sp_1", "bh_galaxy_node_1", "node_0"] tray_id: 2 port_id: 6 } }
        connections { port_a { path: ["bh_galaxy_sp_1", "bh_galaxy_node_2", "node_0"] tray_id: 4 port_id: 6 } port_b { path: ["bh_galaxy_sp_4", "bh_galaxy_node_2", "node_0"] tray_id: 1 port_id: 6 } }
        connections { port_a { path: ["bh_galaxy_sp_4", "bh_galaxy_node_2", "node_0"] tray_id: 3 port_id: 6 } port_b { path: ["bh_galaxy_sp_3", "bh_galaxy_node_2", "node_0"] tray_id: 2 port_id: 6 } }
        connections { port_a { path: ["bh_galaxy_sp_3", "bh_galaxy_node_2", "node_0"] tray_id: 4 port_id: 6 } port_b { path: ["bh_galaxy_sp_5", "bh_galaxy_node_2", "node_0"] tray_id: 1 port_id: 6 } }
